#!/usr/bin/env bash
###############################################################################
# .nbrc
#
# Configuration file for `nb`, a command line note-taking, bookmarking,
# and knowledge base application with encryption, search, Git-backed syncing,
# and more in a single portable script.
#
# Edit this file manually or manage settings using the `nb settings`
# subcommand. Configuration options are set as environment variables, eg:
#   export NB_ENCRYPTION_TOOL=gpg
#
# https://github.com/xwmx/nb
###############################################################################


export NB_FOOTER="${NB_FOOTER:-0}" # Set by `nb` • Wed Apr  2 21:58:04 CST 2025

export NB_DIR="${NB_DIR:-"/Users/haowen_jiang/Library/Mobile Documents/iCloud~md~obsidian/Documents"}" # Set by `nb` • Wed Apr  2 22:02:56 CST 2025


export NB_HEADER="${NB_HEADER:-1}" # Set by `nb` • Wed Apr  2 22:19:01 CST 2025


# Set default tool for viewing markdown files
export NB_MARKDOWN_TOOL="bat"
# Set default tool for viewing directories
export NB_DIRECTORY_TOOL="eza"
# Set default tool, visidata, for viewing tabular files
export NB_DATA_TOOL="vd"
# Set default tool for viewing images
export NB_IMAGE_TOOL="viu"
# Set the number of notes and folders displayed when running `nb`
export NB_LIMIT=10
# Set to '0' to hide the 'Donate' and 'Sponsor' links in `nb browse`.
export NB_BROWSE_SUPPORT_LINKS=0


export NB_SYNTAX_THEME="${NB_SYNTAX_THEME:-gruvbox-dark}" # Set by `nb` • Mon Dec 15 17:49:17 CST 2025

export NB_COLOR_THEME="${NB_COLOR_THEME:-ocean}" # Set by `nb` • Mon Dec 15 17:58:01 CST 2025

export EDITOR="zed" # Set by `nb` • Fri Jun 26 09:24:12 CST 2026
